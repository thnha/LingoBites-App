# Copy this file to .env.ios-build.local and fill real values.
# Do not commit .env.ios-build.local.

APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=

# Base64 encoded App Store Connect .p8 content:
# base64 -i AuthKey_XXXXXXXXXX.p8 | pbcopy
# This key is also passed to xcodebuild so automatic signing can create or
# download App Store provisioning profiles during archive/export.
APP_STORE_CONNECT_API_KEY=

# Optional.
# APPLE_ID=
# APP_STORE_CONNECT_TEAM_ID=
# BUILD_NUMBER=
# IOS_APP_BUILD_NUMBER=

# Required for iOS archive/export signing.
IOS_DEVELOPMENT_TEAM=

# Optional signing override. Prefer IOS_PROVISIONING_PROFILE_PATH when you want
# Fastlane to install and use an exact .mobileprovision file.
# IOS_PROVISIONING_PROFILE_PATH=/absolute/path/LingoBites_Staging_App_Store.mobileprovision
# IOS_PROVISIONING_PROFILE_SPECIFIER=LingoBites Staging App Store
