# Copy this file to .env.android-build.local and fill real values.
# Do not commit .env.android-build.local or the Google Play service account JSON.

# Path to Google Play Console service account JSON.
PLAY_STORE_JSON_KEY_FILE=

# Optional. Default is internal.
# Use production only when you intentionally want to publish to production.
# PLAY_STORE_TRACK=internal
# PLAY_STORE_TRACK=production

# Optional. Default is completed.
# PLAY_STORE_RELEASE_STATUS=completed

