# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

project 'ScanLearnEnglish',
  'DebugDev' => :debug,
  'ReleaseDev' => :release,
  'DebugStag' => :debug,
  'ReleaseStag' => :release,
  'DebugProd' => :debug,
  'ReleaseProd' => :release

target 'ScanLearnEnglish' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # App bundles a subset MaterialIcons.ttf via assets/fonts — skip pod font payloads.
    installer.pods_project.targets.each do |target|
      next unless target.name == 'RNVectorIcons'

      target.resources_build_phase.files.to_a.each do |file|
        path = file.file_ref&.path
        next unless path&.end_with?('.ttf')

        target.resources_build_phase.remove_file_reference(file.file_ref)
      end
    end

  end

  # Run after CocoaPods integrates the user project so resource scripts/file lists
  # are final before we strip duplicate vector-icon fonts.
  post_integrate do |installer|
    support_files = File.join(installer.sandbox.root, 'Target Support Files/Pods-ScanLearnEnglish')
    resources_script = File.join(support_files, 'Pods-ScanLearnEnglish-resources.sh')
    vector_icons_font_pattern = %r{^\s*install_resource "\$\{PODS_ROOT\}/\.\./\.\./\.\./\.\./node_modules/react-native-vector-icons/Fonts/.*\.ttf"\n}

    if File.exist?(resources_script)
      contents = File.read(resources_script)
      updated = contents.gsub(vector_icons_font_pattern, '')
      File.write(resources_script, updated) if updated != contents
    end

    Dir.glob(File.join(support_files, 'Pods-ScanLearnEnglish-resources-*-input-files.xcfilelist')).each do |file|
      lines = File.readlines(file).reject { |line| line.include?('react-native-vector-icons/Fonts/') }
      File.write(file, lines.join)
    end

    Dir.glob(File.join(support_files, 'Pods-ScanLearnEnglish-resources-*-output-files.xcfilelist')).each do |file|
      lines = File.readlines(file).reject { |line| line.end_with?(".ttf\n") }
      File.write(file, lines.join)
    end
  end
end
